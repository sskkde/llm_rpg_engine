# =============================================================================
# LLM RPG Engine - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL connection string (production/development)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llm_rpg

# For testing (SQLite in-memory)
# Tests automatically use this regardless of DATABASE_URL
TEST_DATABASE_URL=sqlite:///./test.db

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis connection string (optional, for caching)
# Set to empty or remove if not using Redis
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# OpenAI API Key (required for production LLM calls)
# If not set, system falls back to MockLLMProvider
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI Model selection (optional, defaults to gpt-4)
# OPENAI_MODEL=gpt-4

# =============================================================================
# Security Configuration
# =============================================================================

# JWT Secret Key (generate a secure random string for production)
# Minimum 32 characters recommended
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production-minimum-32-chars

# JWT Token expiration in minutes (default: 1440 = 24 hours)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =============================================================================
# Application Settings
# =============================================================================

# Environment: development, testing, production
# - development: Debug mode enabled, legacy dev endpoints available
# - testing: SQLite database, mock LLM provider
# - production: PostgreSQL required, OpenAI provider
APP_ENV=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed CORS origins (comma-separated)
# For development, include frontend and backend URLs
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# In production, set to your domain:
# CORS_ORIGINS=https://yourdomain.com

# =============================================================================
# Frontend Configuration (for Next.js)
# =============================================================================

# Backend API URL (used by frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# Docker Compose Configuration
# =============================================================================

# These are used by docker-compose.yml
# Change these for production deployments

# PostgreSQL settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=llm_rpg

# =============================================================================
# Optional: Feature Flags
# =============================================================================

# Enable/disable SSE streaming (default: true)
# ENABLE_STREAMING=true

# Enable/disable combat system (default: true)
# ENABLE_COMBAT=true

# Enable/disable admin endpoints (default: true)
# ENABLE_ADMIN=true

# Enable/disable debug endpoints (default: true in dev/test)
# ENABLE_DEBUG=true
